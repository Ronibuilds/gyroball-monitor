<Application x:Class="Gyroball.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Gyroball.UI.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Converters shared by every view -->
            <conv:ZoneBrushConverter x:Key="ZoneBrush" />
            <conv:StatusBrushConverter x:Key="StatusBrush" />
            <conv:RevsConverter x:Key="Revs" />
            <conv:TimeConverter x:Key="Time" />
            <conv:RpmConverter x:Key="Rpm" />
            <conv:SessionDateConverter x:Key="SessionDate" />
            <conv:SessionSummaryConverter x:Key="SessionSummary" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:ActiveRpmConverter x:Key="ActiveRpm" />
            <conv:ActiveZoneBrushConverter x:Key="ActiveZoneBrush" />

            <!-- Palette -->
            <Color x:Key="BgColor">#1C1C1E</Color>
            <SolidColorBrush x:Key="CardBrush" Color="#2C2C2E" />
            <SolidColorBrush x:Key="PrimaryText" Color="#F2F2F7" />
            <SolidColorBrush x:Key="SecondaryText" Color="#AEAEB2" />
            <SolidColorBrush x:Key="TertiaryText" Color="#8E8E93" />
            <SolidColorBrush x:Key="Separator" Color="#38383A" />
            <SolidColorBrush x:Key="AccentYellow" Color="#FFD60A" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

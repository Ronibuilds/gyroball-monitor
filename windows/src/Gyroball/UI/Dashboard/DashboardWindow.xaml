<Window x:Class="Gyroball.UI.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gyroball" Width="920" Height="600" MinWidth="760" MinHeight="480"
        Background="#1C1C1E" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#161618" BorderBrush="{StaticResource Separator}" BorderThickness="0,0,1,0">
            <DockPanel Margin="10">
                <Button x:Name="OverviewButton" DockPanel.Dock="Top" Click="OnOverviewClick"
                        Content="📈  Overview" HorizontalContentAlignment="Left" Padding="10,8"
                        Background="Transparent" Foreground="{StaticResource PrimaryText}"
                        BorderThickness="0" Cursor="Hand" FontSize="14" />

                <TextBlock DockPanel.Dock="Top" Text="SESSIONS" Margin="10,16,0,6"
                           FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TertiaryText}" />

                <TextBlock x:Name="EmptyHint" DockPanel.Dock="Top" Text="No sessions yet"
                           Margin="10,4,0,0" FontSize="13" Foreground="{StaticResource TertiaryText}"
                           Visibility="Collapsed" />

                <ListBox x:Name="SessionsList" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding Store.Sessions}" SelectionChanged="OnSessionSelected"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,4">
                                <TextBlock Text="{Binding StartedAt, Converter={StaticResource SessionDate}}"
                                           FontSize="13" Foreground="{StaticResource PrimaryText}" />
                                <TextBlock Text="{Binding Converter={StaticResource SessionSummary}}"
                                           FontSize="11" Foreground="{StaticResource SecondaryText}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Detail host -->
        <ContentControl x:Name="ContentHost" Grid.Column="1" />
    </Grid>
</Window>

<UserControl x:Class="Gyroball.UI.Dashboard.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border CornerRadius="12" Padding="16" Background="#26FFFFFF" BorderThickness="1" BorderBrush="#22FFFFFF">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="22" Height="22" CornerRadius="6"
                        Background="{Binding AccentBrush, ElementName=Root}">
                    <TextBlock Text="{Binding Glyph, ElementName=Root}" FontFamily="Segoe MDL2 Assets"
                               FontSize="11" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding Title, ElementName=Root}" Margin="7,0,0,0"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource SecondaryText}" />
            </StackPanel>
            <TextBlock Text="{Binding Value, ElementName=Root}" Margin="0,10,0,0"
                       FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" />
        </StackPanel>
    </Border>
</UserControl>

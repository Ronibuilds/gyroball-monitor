{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Gyroball",
            "type": "shell",
            "command": "bash run.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$swiftc"]
        },
        {
            "label": "Build only",
            "type": "shell",
            "command": "swift build",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$swiftc"]
        }
    ]
}
